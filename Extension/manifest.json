{
  "manifest_version": 3,
  "name": "Maarga_test",
  "version": "2.1",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "icons" : {
    "16": "front.png",
    "48": "front.png",
    "128": "front.png"
  },

  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["popup.html", "style.css", "popup.js", "logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
